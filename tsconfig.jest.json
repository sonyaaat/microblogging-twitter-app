{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "rootDir": ".",
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["__tests__/**/*.ts", "__tests__/**/*.tsx", "test-utils/**/*.ts", "lib/**/*.ts", "app/**/*.ts", "components/**/*.tsx"]
}
